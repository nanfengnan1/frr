[submodule "deps/libssh"]
    path = deps/libssh-mirror
    url = https://github.com/libssh/libssh-mirror.git
    branch = libssh-0.7.0
[submodule "deps/sysrepo"]
	path = deps/sysrepo
	url = https://github.com/sysrepo/sysrepo.git
	branch = origin/v2.1.42
[submodule "deps/netopeer2"]
	path = deps/netopeer2
	url = https://github.com/CESNET/netopeer2.git
	branch = origin/v2.1.16
[submodule "deps/uncrustify"]
	path = deps/uncrustify
	url = https://github.com/uncrustify/uncrustify.git
	branch = origin/uncrustify-0.77.1
[submodule "deps/cmocka"]
	path = deps/cmocka
	url = https://github.com/clibs/cmocka.git
	branch = origin/cmocka-1.0.1
[submodule "deps/libyang"]
	path = deps/libyang
	url = https://github.com/CESNET/libyang.git
	branch = origin/v2.1.128
[submodule "deps/libnetconf2"]
	path = deps/libnetconf2
	url = https://github.com/CESNET/libnetconf2.git
	branch = origin/v2.1.7
[submodule "deps/protobuf"]
	path = deps/protobuf
	url = https://github.com/protocolbuffers/protobuf.git
	branch = origin/origin/v3.21.0
[submodule "deps/protobuf-c"]
	path = deps/protobuf-c
	url = https://github.com/protobuf-c/protobuf-c.git
	branch = v1.5.0
